# DARA — environment template (NO SECRETS IN THIS FILE)
#
# The Vercel project (crucible-insight/ci-dara) is the source of truth for all
# runtime secrets. This file documents the variables the app reads; it must only
# ever contain placeholders. Real values live in Vercel and, for local dev, in a
# gitignored .env.local (never committed — see .gitignore / DARA-002).
#
# To populate local dev, copy real values from the Vercel dashboard into
# .env.local. Note: the DATABASE_URL_APP / DATABASE_URL_ADMIN least-privilege role
# URLs are Production-scoped in Vercel; mirror them into .env.local by hand.
# Rotate any secret on suspicion of exposure (see prisma/security/DARA-002-secrets.md).

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
APP_KEY=                      # 32+ bytes of entropy; keys AES-256-GCM at-rest encryption
                              # and signs the MFA backup-code recovery marker (DARA-031)

# --- Two-factor auth (MFA / DARA-031) ---
# No dedicated secret is required. TOTP 2FA uses Supabase Auth's native MFA — Supabase
# generates and stores the TOTP secret, so there is NO TOTP_ENCRYPTION_KEY to set. Backup
# codes are bcrypt-hashed in the DB and the recovery marker is signed with APP_KEY above.
# OPERATOR STEP: enable the TOTP factor in the Supabase dashboard
# (Authentication → Providers → Multi-Factor Authentication → TOTP = ON) so enrollment works.

# --- Supabase (Auth + Storage) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=    # server-only; never expose to the client

# --- Database (Prisma 7 pg adapter) ---
# DARA-004 least-privilege roles. Production REQUIRES the two role URLs (no owner fallback).
DATABASE_URL_APP=             # restricted runtime role (dara_app, RLS-enforced)
DATABASE_URL_ADMIN=           # cross-tenant runtime role (dara_admin)
DIRECT_URL=                   # owner role (postgres) — migrations / owner-only SQL only
DATABASE_URL=                 # dev-only fallback when the role URLs are unset

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Platform LLM (BYOK overrides per-company in Settings) ---
PLATFORM_ANTHROPIC_KEY=
# PLATFORM_OPENAI_KEY=        # optional; only if platform OpenAI evaluation is used
# PLATFORM_GOOGLE_KEY=        # optional; only if platform Google evaluation is used

# --- Access control ---
PLATFORM_ADMIN_EMAILS=        # comma-separated allow-list of platform admins
