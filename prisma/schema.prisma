generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  trial
  starter
  pro
  enterprise
}

enum PlanStatus {
  active
  past_due
  canceled
  trialing
}

enum AIKeyMode {
  platform
  byok
}

enum AIProvider {
  anthropic
  openai
  google
}

enum UserRole {
  company_admin
  dept_admin
  manager
  reviewer
}

enum InvitationStatus {
  pending
  accepted
  revoked
  expired
}

enum ExtractionStatus {
  pending
  processing
  complete
  failed
}

enum EvaluationStatus {
  pending
  running
  complete
  failed
}

enum JobType {
  evaluate
  extract
  generate_matrix
}

// Where a requirement originated in the solicitation. Drives the compliance matrix
// grouping; `evaluation_factor` requirements are the ones a review scores.
enum RequirementSource {
  instruction       // Section L — proposal preparation/format instructions
  evaluation_factor // Section M — evaluation factors/subfactors (scored)
  sow_pws           // SOW/PWS/SOO task or "shall" statement
  far_clause        // FAR/DFARS clause, provision, or representation
  other
}

// Coverage status tracked per requirement on the compliance matrix.
enum ComplianceStatus {
  not_assessed
  compliant
  partial
  non_compliant
  not_applicable
}

// Color-team gate label for a review. A freeform label only — review behavior comes
// from the chosen personas, not the color.
enum ColorTeam {
  pink
  red
  gold
  blue
  green
  black
  white
}

// Lifecycle of a color-team review.
enum ReviewStatus {
  draft
  in_progress
  complete
}

// What a solicitation document is: the RFP itself, an amendment to it, or our own
// proposal working draft (which reviews snapshot).
enum DocType {
  rfp
  amendment
  proposal
}

// Lifecycle of an amendment's AI reconciliation against the compliance matrix.
enum ReconciliationStatus {
  pending  // uploaded, not yet reconciled
  proposed // AI has proposed changes awaiting review
  applied  // changes resolved (accepted/rejected) and folded into the matrix
}

// A proposed compliance-matrix change derived from an amendment.
enum ChangeType {
  add
  modify
  remove
}

enum ChangeStatus {
  proposed
  accepted
  rejected
}

enum JobStatus {
  pending
  running
  done
  failed
}

model Company {
  id               BigInt     @id @default(autoincrement())
  name             String     @db.VarChar(255)
  slug             String     @unique @db.VarChar(100)
  plan             Plan       @default(trial)
  planStatus       PlanStatus @default(trialing) @map("plan_status")
  trialEndsAt      DateTime?  @map("trial_ends_at")
  stripeCustomerId String?    @map("stripe_customer_id") @db.VarChar(100)
  stripeSubId      String?    @unique @map("stripe_sub_id") @db.VarChar(100)
  aiKeyMode        AIKeyMode  @default(platform) @map("ai_key_mode")
  activeProvider   AIProvider @default(anthropic) @map("active_provider")
  activeModel      String     @default("claude-sonnet-4-6") @map("active_model") @db.VarChar(100)
  anthropicKeyEnc  String?    @map("anthropic_key_enc")
  openaiKeyEnc     String?    @map("openai_key_enc")
  googleKeyEnc     String?    @map("google_key_enc")
  onboardedAt      DateTime?  @map("onboarded_at")

  // Company profile (editable on /app/company by company admins)
  legalName        String?    @map("legal_name") @db.VarChar(255)
  website          String?    @db.VarChar(255)
  phone            String?    @db.VarChar(50)
  cageCode         String?    @map("cage_code") @db.VarChar(20)
  ueiCode          String?    @map("uei_code") @db.VarChar(20)
  addressLine1     String?    @map("address_line1") @db.VarChar(255)
  addressLine2     String?    @map("address_line2") @db.VarChar(255)
  city             String?    @db.VarChar(120)
  state            String?    @db.VarChar(120)
  postalCode       String?    @map("postal_code") @db.VarChar(20)
  country          String?    @db.VarChar(120)

  // CMMC assessment + C3PAO (auditor) information
  cmmcTargetLevel  String?    @map("cmmc_target_level") @db.VarChar(20)
  cmmcStatus       String?    @map("cmmc_status") @db.VarChar(40)
  c3paoName        String?    @map("c3pao_name") @db.VarChar(255)
  c3paoContact     String?    @map("c3pao_contact") @db.VarChar(255)
  c3paoEmail       String?    @map("c3pao_email") @db.VarChar(255)
  c3paoPhone       String?    @map("c3pao_phone") @db.VarChar(50)
  assessmentDate   DateTime?  @map("assessment_date")
  certExpiresAt    DateTime?  @map("cert_expires_at")

  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  users         DaraUser[]
  solicitations Solicitation[]
  personas      Persona[]
  evaluations   Evaluation[]
  results       Result[]
  jobQueue      JobQueue[]
  teams         Team[]
  teamMembers   TeamMember[]
  invitations   Invitation[]
  solicitationDepartments SolicitationDepartment[]

  @@index([plan, planStatus])
  @@map("dara_companies")
}

model DaraUser {
  id          String    @id @db.Uuid
  companyId   BigInt    @map("company_id")
  email       String    @unique @db.VarChar(255)
  name        String    @default("") @db.VarChar(255)
  role        UserRole  @default(company_admin)
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")
  onboardedAt DateTime? @map("onboarded_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  teamMemberships TeamMember[]

  @@index([companyId])
  @@map("dara_users")
}

// Application (platform) admins: company-less operators who manage backend/platform
// settings and users but have NO access to company CUI. Keyed by email so an admin
// can be granted before they first sign in; userId is filled on first sign-in.
// Accessed only via prismaAdmin (dara_admin); the tenant runtime role has no grant.
model PlatformAdmin {
  id          BigInt    @id @default(autoincrement())
  email       String    @unique @db.VarChar(255)
  name        String    @default("") @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  userId      String?   @map("user_id") @db.Uuid
  addedBy     String?   @map("added_by") @db.VarChar(255)
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("dara_platform_admins")
}

// Singleton platform AI configuration: the platform-supplied API keys (used by
// companies in 'platform' mode) and the centrally-selected provider/model. Managed
// only from the Application Admin console; accessed via prismaAdmin (dara_admin).
model PlatformSetting {
  id              Int        @id @default(1)
  activeProvider  AIProvider @default(anthropic) @map("active_provider")
  activeModel     String     @default("claude-sonnet-4-6") @map("active_model") @db.VarChar(100)
  anthropicKeyEnc String?    @map("anthropic_key_enc")
  openaiKeyEnc    String?    @map("openai_key_enc")
  googleKeyEnc    String?    @map("google_key_enc")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@map("dara_platform_settings")
}

model Team {
  id          BigInt   @id @default(autoincrement())
  companyId   BigInt   @map("company_id")
  name        String   @db.VarChar(255)
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company       Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members       TeamMember[]
  invitations   Invitation[]
  solicitations SolicitationDepartment[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("dara_teams")
}

model TeamMember {
  id        BigInt   @id @default(autoincrement())
  companyId BigInt   @map("company_id")
  teamId    BigInt   @map("team_id")
  userId    String   @map("user_id") @db.Uuid
  role      UserRole @default(reviewer)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  team    Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user    DaraUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([companyId])
  @@index([teamId])
  @@index([userId])
  @@map("dara_team_members")
}

model Invitation {
  id          BigInt           @id @default(autoincrement())
  companyId   BigInt           @map("company_id")
  teamId      BigInt?          @map("team_id")
  email       String           @db.VarChar(255)
  role        UserRole         @default(reviewer)
  status      InvitationStatus @default(pending)
  invitedById String?          @map("invited_by_id") @db.Uuid
  acceptedAt  DateTime?        @map("accepted_at")
  expiresAt   DateTime         @map("expires_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  team    Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([email])
  @@map("dara_invitations")
}

// Which departments a solicitation is shared with. A non-admin user sees a
// solicitation only if it is assigned to a department they belong to (or they
// created it); see utils/dara/sol-access.ts. company_id is denormalized for RLS.
model SolicitationDepartment {
  id             BigInt   @id @default(autoincrement())
  companyId      BigInt   @map("company_id")
  solicitationId BigInt   @map("solicitation_id")
  teamId         BigInt   @map("team_id")
  createdAt      DateTime @default(now()) @map("created_at")

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  solicitation Solicitation @relation(fields: [solicitationId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([solicitationId, teamId])
  @@index([companyId])
  @@index([solicitationId])
  @@index([teamId])
  @@map("dara_solicitation_departments")
}

model Solicitation {
  id          BigInt   @id @default(autoincrement())
  companyId   BigInt   @map("company_id")
  title       String   @db.VarChar(500)
  solNumber   String   @default("") @map("sol_number") @db.VarChar(100)
  agency      String   @default("") @db.VarChar(255)
  notes       String?
  createdBy   String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company      Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  solDocs      SolDocument[]
  requirements Requirement[]
  reviews      Review[]
  evaluations  Evaluation[]
  departments  SolicitationDepartment[]
  amendments   Amendment[]

  @@index([companyId])
  @@map("dara_solicitations")
}

model SolDocument {
  id               BigInt           @id @default(autoincrement())
  companyId        BigInt           @map("company_id")
  solicitationId   BigInt           @map("solicitation_id")
  // rfp = the solicitation itself, amendment = an amendment to it,
  // proposal = our own working draft that reviews snapshot.
  docType          DocType          @default(rfp) @map("doc_type")
  // When docType = amendment, the amendment this file belongs to.
  amendmentId      BigInt?          @map("amendment_id")
  originalFilename String           @map("original_filename") @db.VarChar(500)
  storedFilename   String           @map("stored_filename") @db.VarChar(500)
  fileSize         Int              @default(0) @map("file_size")
  extractionStatus ExtractionStatus @default(pending) @map("extraction_status")
  extractedText    String?          @map("extracted_text")
  uploadedBy       String?          @map("uploaded_by") @db.Uuid
  uploadedAt       DateTime         @default(now()) @map("uploaded_at")

  solicitation Solicitation @relation(fields: [solicitationId], references: [id], onDelete: Cascade)
  amendment    Amendment?   @relation(fields: [amendmentId], references: [id], onDelete: Cascade)

  @@index([solicitationId])
  @@index([companyId])
  @@index([amendmentId])
  @@map("dara_sol_documents")
}

// A single discrete requirement shredded from the solicitation — the row unit of
// the compliance matrix. Evolved from the former Criterion model: `source` records
// where it came from, `isScored` marks the Section M factors a review scores, and
// complianceStatus/proposalRef track coverage. The compliance matrix for a
// solicitation is the set of its (non-removed) requirements.
model Requirement {
  id               BigInt            @id @default(autoincrement())
  companyId        BigInt            @map("company_id")
  solicitationId   BigInt            @map("solicitation_id")
  name             String            @db.VarChar(300) // short label / handle
  description      String? // full requirement / "shall" text
  source           RequirementSource @default(evaluation_factor)
  isScored         Boolean           @default(true) @map("is_scored")
  farReference     String            @default("") @map("far_reference") @db.VarChar(100)
  // Where this requirement is cited in the solicitation (e.g. "Section L.4.2", "PWS 3.1").
  citation         String            @default("") @db.VarChar(200)
  weight           Int               @default(0)
  complianceStatus ComplianceStatus  @default(not_assessed) @map("compliance_status")
  proposalRef      String            @default("") @map("proposal_ref") @db.VarChar(300)
  sortOrder        Int               @default(0) @map("sort_order")

  // Amendment provenance (Phase 3). removedAt marks a requirement struck by an
  // amendment — retained, never deleted (excluded from the active matrix).
  version              Int       @default(0)
  addedByAmendmentId   BigInt?   @map("added_by_amendment_id")
  changedByAmendmentId BigInt?   @map("changed_by_amendment_id")
  removedByAmendmentId BigInt?   @map("removed_by_amendment_id")
  removedAt            DateTime? @map("removed_at")

  solicitation     Solicitation         @relation(fields: [solicitationId], references: [id], onDelete: Cascade)
  results          Result[]
  versions         RequirementVersion[]
  amendmentChanges AmendmentChange[]

  @@index([solicitationId])
  @@index([companyId])
  @@map("dara_requirements")
}

// Snapshot of a Requirement taken just before an amendment modifies it — the
// prior-version log (mirrors ResultVersion). Append-only; company_id-keyed for RLS.
model RequirementVersion {
  id               BigInt            @id @default(autoincrement())
  companyId        BigInt            @map("company_id")
  requirementId    BigInt            @map("requirement_id")
  version          Int
  name             String            @db.VarChar(300)
  description      String?
  source           RequirementSource
  isScored         Boolean
  farReference     String            @db.VarChar(100)
  weight           Int
  complianceStatus ComplianceStatus
  proposalRef      String            @db.VarChar(300)
  amendmentId      BigInt?           @map("amendment_id")
  createdAt        DateTime          @default(now()) @map("created_at")

  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([requirementId])
  @@map("dara_requirement_versions")
}

// An amendment to a solicitation. Its documents (SolDocument docType=amendment) are
// AI-diffed against the current compliance matrix to propose changes (AmendmentChange)
// that, once accepted, fold into the matrix and version any modified requirements.
model Amendment {
  id                   BigInt               @id @default(autoincrement())
  companyId            BigInt               @map("company_id")
  solicitationId       BigInt               @map("solicitation_id")
  number               String               @default("") @db.VarChar(50)
  title                String               @default("") @db.VarChar(300)
  effectiveDate        DateTime?            @map("effective_date")
  reconciliationStatus ReconciliationStatus @default(pending) @map("reconciliation_status")
  aiSummary            String?              @map("ai_summary")
  appliedAt            DateTime?            @map("applied_at")
  createdBy            String?              @map("created_by") @db.Uuid
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @default(now()) @updatedAt @map("updated_at")

  solicitation Solicitation      @relation(fields: [solicitationId], references: [id], onDelete: Cascade)
  documents    SolDocument[]
  changes      AmendmentChange[]

  @@index([solicitationId])
  @@index([companyId])
  @@map("dara_amendments")
}

// One proposed compliance-matrix change derived from an amendment, awaiting review.
// proposed = the new requirement fields (add/modify); requirementId targets the
// existing requirement for modify/remove (null for add).
model AmendmentChange {
  id            BigInt       @id @default(autoincrement())
  companyId     BigInt       @map("company_id")
  amendmentId   BigInt       @map("amendment_id")
  requirementId BigInt?      @map("requirement_id")
  changeType    ChangeType   @map("change_type")
  proposed      Json?
  rationale     String?
  status        ChangeStatus @default(proposed)
  createdAt     DateTime     @default(now()) @map("created_at")

  amendment   Amendment    @relation(fields: [amendmentId], references: [id], onDelete: Cascade)
  requirement Requirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([amendmentId])
  @@map("dara_amendment_changes")
}

model Persona {
  id           BigInt   @id @default(autoincrement())
  companyId    BigInt   @map("company_id")
  displayName  String   @map("display_name") @db.VarChar(200)
  systemPrompt String   @map("system_prompt")
  isActive     Boolean  @default(true) @map("is_active")
  icon         String?  @db.VarChar(16)
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  results        Result[]
  reviewPersonas ReviewPersona[]

  @@index([companyId, isActive])
  @@map("dara_personas")
}

// A color-team gate review of the company's own proposal at a point in time
// (evolved from the former Response/offeror model). `colorTeam` is a freeform label;
// the review's behavior comes from its chosen personas (ReviewPersona). Each review
// freezes the proposal working draft into ReviewDocument snapshots so the gate is
// anchored to what it saw. The DB table/columns keep the old names where remapping
// avoids churn (table dara_reviews ex dara_responses; name ex offeror_name).
model Review {
  id             BigInt       @id @default(autoincrement())
  companyId      BigInt       @map("company_id")
  solicitationId BigInt       @map("solicitation_id")
  name           String       @map("offeror_name") @db.VarChar(300)
  colorTeam      ColorTeam    @default(pink) @map("color_team")
  status         ReviewStatus @default(draft)
  notes          String?
  snapshotAt     DateTime?    @map("snapshot_at")
  createdBy      String?      @map("created_by") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at")

  solicitation   Solicitation     @relation(fields: [solicitationId], references: [id], onDelete: Cascade)
  documents      ReviewDocument[]
  reviewPersonas ReviewPersona[]
  evaluations    Evaluation[]

  @@index([solicitationId])
  @@index([companyId])
  @@map("dara_reviews")
}

// A frozen snapshot of one proposal-draft document captured for a review (evolved
// from ResponseFile). Holds a copy of the extracted text at capture time so the
// review reflects the draft as it was, even if the live proposal doc changes later.
model ReviewDocument {
  id               BigInt           @id @default(autoincrement())
  companyId        BigInt           @map("company_id")
  reviewId         BigInt           @map("response_id")
  originalFilename String           @map("original_filename") @db.VarChar(500)
  storedFilename   String           @map("stored_filename") @db.VarChar(500)
  fileSize         Int              @default(0) @map("file_size")
  extractionStatus ExtractionStatus @default(pending) @map("extraction_status")
  extractedText    String?          @map("extracted_text")
  capturedAt       DateTime         @default(now()) @map("uploaded_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([companyId])
  @@map("dara_review_documents")
}

// Which personas (reviewers) run in a review. Freeform selection; if a review has
// none, the run falls back to all active personas.
model ReviewPersona {
  id        BigInt @id @default(autoincrement())
  companyId BigInt @map("company_id")
  reviewId  BigInt @map("review_id")
  personaId BigInt @map("persona_id")

  review  Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  persona Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@unique([reviewId, personaId])
  @@index([companyId])
  @@index([reviewId])
  @@map("dara_review_personas")
}

model Evaluation {
  id             BigInt           @id @default(autoincrement())
  companyId      BigInt           @map("company_id")
  solicitationId BigInt           @map("solicitation_id")
  // Column stays `response_id` (no DB rename); the relation now points at Review.
  reviewId       BigInt           @map("response_id")
  personaId      BigInt           @map("persona_id")
  status         EvaluationStatus @default(pending)
  errorMessage   String?          @map("error_message") @db.VarChar(500)
  completedAt    DateTime?        @map("completed_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  solicitation Solicitation @relation(fields: [solicitationId], references: [id], onDelete: Cascade)
  review       Review       @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  results      Result[]

  @@index([companyId])
  @@index([solicitationId])
  @@index([status])
  @@map("dara_evaluations")
}

model Result {
  id              BigInt   @id @default(autoincrement())
  evaluationId    BigInt   @map("evaluation_id")
  companyId       BigInt   @map("company_id")
  // Column stays `criterion_id` (no DB rename) — the FK/unique index keep their
  // names; the relation now points at Requirement.
  requirementId   BigInt   @map("criterion_id")
  personaId       BigInt   @map("persona_id")
  aiDetermination String?  @map("ai_determination") @db.VarChar(50)
  aiScore         Decimal? @map("ai_score") @db.Decimal(5, 2)
  aiRationale     String?  @map("ai_rationale")
  aiConfidence    Decimal? @map("ai_confidence") @db.Decimal(5, 4)
  aiStrengths     Json?    @map("ai_strengths")
  aiWeaknesses    Json?    @map("ai_weaknesses")
  aiCompliance    String?  @map("ai_compliance")
  aiSuggestedChanges Json? @map("ai_suggested_changes")
  aiReview        Json?    @map("ai_review")
  regenCount      Int      @default(0) @map("regen_count")
  archivedAt      DateTime? @map("archived_at")
  modelId         String?  @map("model_id") @db.VarChar(100)
  tokenIn         Int      @default(0) @map("token_in")
  tokenOut        Int      @default(0) @map("token_out")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  evaluation  Evaluation  @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  persona     Persona     @relation(fields: [personaId], references: [id], onDelete: Cascade)
  versions    ResultVersion[]

  @@unique([evaluationId, requirementId, personaId])
  @@index([companyId])
  @@index([evaluationId])
  @@map("dara_results")
}

// Snapshot of a Result taken just before it is regenerated — the prior-version log.
// Append-only history; never shown as a live result. company_id-keyed for RLS.
model ResultVersion {
  id                 BigInt   @id @default(autoincrement())
  companyId          BigInt   @map("company_id")
  resultId           BigInt   @map("result_id")
  version            Int
  aiDetermination    String?  @map("ai_determination") @db.VarChar(50)
  aiScore            Decimal? @map("ai_score") @db.Decimal(5, 2)
  aiRationale        String?  @map("ai_rationale")
  aiConfidence       Decimal? @map("ai_confidence") @db.Decimal(5, 4)
  aiStrengths        Json?    @map("ai_strengths")
  aiWeaknesses       Json?    @map("ai_weaknesses")
  aiCompliance       String?  @map("ai_compliance")
  aiSuggestedChanges Json?    @map("ai_suggested_changes")
  aiReview           Json?    @map("ai_review")
  modelId            String?  @map("model_id") @db.VarChar(100)
  createdAt          DateTime @default(now()) @map("created_at")

  result Result @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([resultId])
  @@map("dara_result_versions")
}

model JobQueue {
  id          BigInt    @id @default(autoincrement())
  companyId   BigInt    @map("company_id")
  jobType     JobType   @map("job_type")
  payload     Json
  status      JobStatus @default(pending)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3) @map("max_attempts")
  error       String?
  availableAt DateTime  @default(now()) @map("available_at")
  startedAt   DateTime? @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([status, availableAt])
  @@index([companyId])
  @@map("dara_job_queue")
}

// DARA-013: append-only audit trail. No Company relation/cascade on purpose — the
// trail must survive company deletion. Written/read only via the privileged
// client (dara_admin); the app role has no access. Append-only is enforced at the
// grant level (SELECT/INSERT only — no UPDATE/DELETE).
model AuditLog {
  id         BigInt   @id @default(autoincrement())
  companyId  BigInt?  @map("company_id")
  actorId    String?  @map("actor_id") @db.Uuid
  actorEmail String   @default("") @map("actor_email") @db.VarChar(255)
  action     String   @db.VarChar(100)
  entityType String   @default("") @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.VarChar(100)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([companyId, createdAt])
  @@index([action])
  @@map("dara_audit_log")
}
